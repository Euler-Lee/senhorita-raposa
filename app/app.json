      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "package": "com.eulerlee.senhorita_raposa"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8389ffcf-8f3d-4b32-96bb-9e49fcb8b4b4"
      }
    },
    "owner": "eulerlee",
    "plugins": [
      "expo-web-browser"
    ]
  }
}
