{
  "expo": {
    "name": "Senhorita Raposa",
    "slug": "senhorita-raposa",
    "scheme": "sra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#D85A10"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
